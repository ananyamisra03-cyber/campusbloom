PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/campusbloom?retryWrites=true&w=majority

# JWT — use a long random string (32+ chars)
JWT_SECRET=replace_with_a_very_long_random_secret_string_here
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Gmail — enable 2FA, then create an App Password at:
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM="CampusBloom <your.email@gmail.com>"
